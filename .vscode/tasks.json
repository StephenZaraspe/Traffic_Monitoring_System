{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Train Full Dataset",
            "type": "shell",
            "command": "${workspaceFolder}/venv/Scripts/python.exe",
            "args": [
                "${workspaceFolder}/scripts/train_yolov8_full.py"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run Evaluation",
            "type": "shell",
            "command": "${workspaceFolder}/venv/Scripts/python.exe",
            "args": [
                "${workspaceFolder}/scripts/evaluate_model.py"
            ],
            "group": "test"
        },
        {
            "label": "Check GPU",
            "type": "shell",
            "command": "${workspaceFolder}/venv/Scripts/python.exe",
            "args": [
                "${workspaceFolder}/scripts/test_gpu.py"
            ],
            "group": "test"
        }
    ]
}